<Window x:Class="MuteMaster.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About MuteMaster"
        Width="380" Height="560"
        MinWidth="340" MinHeight="480"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/tray_active.ico"
        Background="#1E1E1E"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#0F6E56" Padding="24">
            <StackPanel HorizontalAlignment="Center">
                <!-- Logo -->
                <Border Width="56" Height="56" CornerRadius="14"
                        Background="#1A9E75" HorizontalAlignment="Center"
                        Margin="0,0,0,12">
                    <Canvas Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Stroke="White" StrokeThickness="2"
                              Data="M 13,1 C 11,1 9,2.8 9,5 L 9,13 C 9,15.2 11,17 13,17 C 15,17 17,15.2 17,13 L 17,5 C 17,2.8 15,1 13,1 Z"/>
                        <Path Stroke="White" StrokeThickness="2"
                              Data="M 21,11 L 21,13 C 21,17.4 17.4,21 13,21 C 8.6,21 5,17.4 5,13 L 5,11"/>
                        <Line X1="13" Y1="21" X2="13" Y2="25" Stroke="White" StrokeThickness="2"/>
                        <Line X1="9" Y1="25" X2="17" Y2="25" Stroke="White" StrokeThickness="2"/>
                    </Canvas>
                </Border>

                <!-- Name and version -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                    <TextBlock Text="MuteMaster" FontSize="20" FontWeight="Medium" Foreground="White"/>
                    <Border Background="#1A9E75" CornerRadius="3" Padding="6,2" Margin="8,2,0,0" VerticalAlignment="Center">
                        <TextBlock Text="v1.0.0" FontSize="11" FontWeight="Medium" Foreground="#A0E8D0"/>
                    </Border>
                </StackPanel>

                <TextBlock Text="Global mic &amp; speaker mute utility for Windows"
                           FontSize="12" Foreground="#A0D4C0" HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center" MaxWidth="280"/>
            </StackPanel>
        </Border>

        <!-- Info rows -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16,24,16">

                <!-- Developer -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Developer" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Muhtasim Mahbub" FontSize="13" Foreground="#F0F0F0" VerticalAlignment="Center"/>
                </Grid>
                <Separator Background="#3A3A3A" Height="0.5" Margin="0,0,0,10"/>

                <!-- Organization -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Organization" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="3M Design Solutions" FontSize="13" Foreground="#F0F0F0" VerticalAlignment="Center"/>
                </Grid>
                <Separator Background="#3A3A3A" Height="0.5" Margin="0,0,0,10"/>

                <!-- Website -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Website" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" FontSize="13" VerticalAlignment="Center">
                        <Hyperlink NavigateUri="https://3mdesignsolutions.com" RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="#1D9E75">3mdesignsolutions.com</Hyperlink>
                    </TextBlock>
                </Grid>
                <Separator Background="#3A3A3A" Height="0.5" Margin="0,0,0,10"/>

                <!-- Contact -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Contact" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" FontSize="13" VerticalAlignment="Center">
                        <Hyperlink NavigateUri="mailto:3mdsolutions25@gmail.com" RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="#1D9E75">3mdsolutions25@gmail.com</Hyperlink>
                    </TextBlock>
                </Grid>
                <Separator Background="#3A3A3A" Height="0.5" Margin="0,0,0,10"/>

                <!-- License -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="License" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="MIT License" FontSize="13" Foreground="#F0F0F0" VerticalAlignment="Center"/>
                </Grid>
                <Separator Background="#3A3A3A" Height="0.5" Margin="0,0,0,10"/>

                <!-- Built with -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Built with" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text=".NET 9  ·  WPF  ·  C#" FontSize="13" Foreground="#F0F0F0" VerticalAlignment="Center"/>
                </Grid>
                <Separator Background="#3A3A3A" Height="0.5" Margin="0,0,0,16"/>

                <!-- Open source -->
                <TextBlock Text="OPEN SOURCE COMPONENTS" FontSize="11" Foreground="#888888"
                           Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,6">
                    <TextBlock Text="NAudio" FontSize="12" Foreground="#CCCCCC" FontFamily="Consolas"/>
                    <TextBlock Text="MIT License" FontSize="12" Foreground="#888888" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="NHotkey.Wpf" FontSize="12" Foreground="#CCCCCC" FontFamily="Consolas"/>
                    <TextBlock Text="MIT License" FontSize="12" Foreground="#888888" HorizontalAlignment="Right"/>
                </Grid>
                <Grid>
                    <TextBlock Text="Hardcodet.NotifyIcon.Wpf" FontSize="12" Foreground="#CCCCCC" FontFamily="Consolas"/>
                    <TextBlock Text="CPOL License" FontSize="12" Foreground="#888888" HorizontalAlignment="Right"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#252525" BorderBrush="#3A3A3A" BorderThickness="0,0.5,0,0" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontSize="11" Foreground="#777777"
                           VerticalAlignment="Center">
                    <Run Text="© 2026 Muhtasim Mahbub"/>
                    <LineBreak/>
                    <Run Text="3M Design Solutions"/>
                </TextBlock>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button Content="Changelog" FontSize="12" Padding="10,5"
                            Background="#1A3A2A" Foreground="#1D9E75"
                            BorderBrush="#1D5040" BorderThickness="0.5"
                            Cursor="Hand" Margin="0,0,8,0" Click="Changelog_Click"/>
                    <Button Content="Close" FontSize="12" Padding="10,5"
                            Background="#333333" Foreground="#F0F0F0"
                            BorderBrush="#555555" BorderThickness="0.5"
                            Cursor="Hand" Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
