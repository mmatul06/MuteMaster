<Window x:Class="MuteMaster.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MuteMaster Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Left="20" Top="20">

    <Window.Resources>
        <SolidColorBrush x:Key="OverlayBg" Color="#181818"/>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Background="{StaticResource OverlayBg}"
            CornerRadius="14"
            Padding="10,8"
            BorderBrush="#28FFFFFF"
            BorderThickness="0.5">

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

            <!-- Icon container — size scales with OverlaySize setting -->
            <Viewbox x:Name="IconViewbox" Width="32" Height="32" Stretch="Uniform">
                <Grid Width="32" Height="32">

                    <!-- Muted background -->
                    <Ellipse x:Name="MutedCircle" Fill="#33E24B4A" Visibility="Collapsed"/>
                    <!-- Active background -->
                    <Ellipse x:Name="ActiveCircle" Fill="#331D9E75" Visibility="Visible"/>

                    <!-- Muted mic icon -->
                    <Canvas x:Name="MutedIcon" Width="18" Height="18"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed">
                        <Path Stroke="#E24B4A" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M 6,6 L 6,9 C 6,11.2 7.8,13 10,13 C 10.8,13 11.5,12.8 12.1,12.3"/>
                        <Path Stroke="#E24B4A" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M 12.6,9.8 L 12.6,6 C 12.6,3.8 10.8,2 8.6,2 C 7.3,2 6.2,2.6 5.5,3.5"/>
                        <Path Stroke="#E24B4A" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M 4,8 L 4,9 C 4,12.3 6.7,15 10,15"/>
                        <Path Stroke="#E24B4A" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M 13.5,11.5 C 14.4,10.8 15,9.7 15,8.5 L 15,8"/>
                        <Line X1="1" Y1="1" X2="17" Y2="17" Stroke="#E24B4A" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        <Line X1="9" Y1="15" X2="9" Y2="18" Stroke="#E24B4A" StrokeThickness="1.6"
                              StrokeStartLineCap="Round"/>
                        <Line X1="6" Y1="18" X2="12" Y2="18" Stroke="#E24B4A" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Canvas>

                    <!-- Active mic icon -->
                    <Canvas x:Name="ActiveIcon" Width="18" Height="18"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Visible">
                        <Path Stroke="#1D9E75" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M 9,1 C 7.3,1 6,2.3 6,4 L 6,9 C 6,10.7 7.3,12 9,12 C 10.7,12 12,10.7 12,9 L 12,4 C 12,2.3 10.7,1 9,1 Z"/>
                        <Path Stroke="#1D9E75" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M 15,8 L 15,9 C 15,12.3 12.3,15 9,15 C 5.7,15 3,12.3 3,9 L 3,8"/>
                        <Line X1="9" Y1="15" X2="9" Y2="18" Stroke="#1D9E75" StrokeThickness="1.6"
                              StrokeStartLineCap="Round"/>
                        <Line X1="6" Y1="18" X2="12" Y2="18" Stroke="#1D9E75" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Canvas>
                </Grid>
            </Viewbox>

            <!-- Level bars -->
            <StackPanel x:Name="LevelBarsPanel"
                        Orientation="Horizontal"
                        VerticalAlignment="Bottom"
                        Margin="8,0,0,2"
                        Visibility="Visible">
                <Rectangle x:Name="Bar1" Width="3" Height="3" Fill="#1D9E75" RadiusX="1.5" RadiusY="1.5" Margin="0,0,2,0" VerticalAlignment="Bottom"/>
                <Rectangle x:Name="Bar2" Width="3" Height="3" Fill="#1D9E75" RadiusX="1.5" RadiusY="1.5" Margin="0,0,2,0" VerticalAlignment="Bottom"/>
                <Rectangle x:Name="Bar3" Width="3" Height="3" Fill="#1D9E75" RadiusX="1.5" RadiusY="1.5" Margin="0,0,2,0" VerticalAlignment="Bottom"/>
                <Rectangle x:Name="Bar4" Width="3" Height="3" Fill="#1D9E75" RadiusX="1.5" RadiusY="1.5" Margin="0,0,2,0" VerticalAlignment="Bottom"/>
                <Rectangle x:Name="Bar5" Width="3" Height="3" Fill="#1D9E75" RadiusX="1.5" RadiusY="1.5" VerticalAlignment="Bottom"/>
            </StackPanel>

            <!-- PTT indicator — shown only when Push to Talk is enabled -->
            <Border x:Name="PttIndicator"
                    Background="#CC333333"
                    CornerRadius="3"
                    Padding="4,2"
                    Margin="6,0,0,0"
                    Visibility="Collapsed"
                    VerticalAlignment="Center">
                <TextBlock Text="PTT" FontSize="9" FontWeight="Medium"
                           Foreground="#EF9F27" VerticalAlignment="Center"/>
            </Border>

        </StackPanel>
    </Border>
</Window>
